1784. Check if Binary String Has at Most One Segment of Ones

Solution in C++ -->

class Solution {
public:
    bool checkOnesSegment(string s) {
        for (int i = 1; i < s.size(); i++) {
            if (s[i] == '1' && s[i-1] == '0') {
                return false;
            }
        }
        return true;
    }
};
